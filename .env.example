# ───────────────────────────────────────────────
# Copy to .env and fill in real values.
# docker-compose and the backend both read these.
# ───────────────────────────────────────────────

# --- Domain (production / Docker) ---
# The domain Caddy serves the site on and gets an HTTPS cert for.
# Production: your real domain, e.g. nijatsadigov.com
# Local Docker test: localhost
DOMAIN=localhost

# --- Postgres ---
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=portfolio

# Connection string the backend uses.
# For local (backend run natively):  host=localhost
# Inside docker-compose:             host=db  (the service name)
DATABASE_URL=postgres://portfolio:change_me_in_production@localhost:5432/portfolio?sslmode=disable

# --- Backend ---
PORT=8090
# Secret used to sign admin JWTs. Generate a long random string.
JWT_SECRET=change_me_to_a_long_random_secret
# Allowed origin for the frontend (CORS). Comma-separated for multiple.
CORS_ORIGIN=http://localhost:5173
# Where uploaded images/resumes are stored on disk, and the public path they serve from.
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:8090

# --- Admin bootstrap ---
# On first start, if no admin exists, one is created from these.
# Change the password after first login (or before deploying).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_now
ADMIN_NAME=Nijat Sadigov

# --- Frontend ---
# Base URL the React app calls. Injected at build time.
VITE_API_BASE_URL=http://localhost:8090
